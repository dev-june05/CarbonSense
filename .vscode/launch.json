// A launch configuration that compiles the extension and then opens it inside a new window.
//This file ensures that the extension still works even if the master folder is open in the VS Code Workspace.
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/extension/carbonsense"
            ],
            "outFiles": [
                "${workspaceFolder}/extension/carbonsense/dist/**/*.js"
            ],
            "preLaunchTask": "npm: compile"
        }
    ]
}